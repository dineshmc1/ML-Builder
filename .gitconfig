[user]
    # Please update your name and email
    name = Dinesh Ramakrishnan
    email = rdineshmc14@gmail.com

[core]
    # Set your preferred editor (e.g., code --wait, vim, nano)
    editor = code --wait
    # Exclude files globally (optional)
    # excludesfile = ~/.gitignore_global
    # Normalize line endings
    autocrlf = true

[init]
    # Set default branch name to main
    defaultBranch = main

[alias]
    # Shortcuts for common commands
    st = status -s
    co = checkout
    cb = checkout -b
    ci = commit
    br = branch
    df = diff
    
    # Beautiful git log graph
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    
    # Unstage a file
    unstage = reset HEAD --

[pull]
    # Fast-forward only by default to avoid merge commits on pull
    ff = only
    # Alternatively, use rebase instead of merge when pulling
    rebase = true

[push]
    # Push the current branch to a branch of the same name by default
    default = current
    # Automatically set upstream branch on push
    autoSetupRemote = true

[color]
    # Enable colors in UI
    ui = auto

[merge]
    # Do not guess on conflict resolution
    conflictstyle = diff3

[fetch]
    # Prune tracking branches that were deleted on the remote
    prune = true
