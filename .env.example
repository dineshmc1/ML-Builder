# -------------------------------------------------------------
# LLM Provider API Keys (litellm supports 100+ providers)
# -------------------------------------------------------------
# Only set the key(s) for the provider(s) you intend to use.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
TOGETHERAI_API_KEY=your_together_api_key_here

# -------------------------------------------------------------
# Weights & Biases (Optional tracking)
# -------------------------------------------------------------
# If you run `wandb login` in the terminal, this is automatic.
# WANDB_API_KEY=your_wandb_api_key_here
